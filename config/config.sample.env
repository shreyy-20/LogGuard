### Sample environment variables for LogGuard
# Copy this to `config/config.env` or export these variables in your environment.
# NEVER commit real secrets. Use a secrets manager or CI/CD environment variables.

# Database
DB_PATH=/app/data/logguard.db

# Log paths (relative to app root)
LOGS_DIR=/app/logs

# SMTP / Email (used only if email notifications enabled)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=alerts@example.com
SMTP_PASSWORD=CHANGE_ME
FROM_EMAIL=logguard-alerts@example.com
TO_EMAIL=admin@example.com

# Performance tuning
DB_BATCH_SIZE=100
DB_FLUSH_INTERVAL=1.0
